# Backend Server Environment Variables
# Copy this to server/.env for local development
# For production, set these in Render/hosting platform dashboard

PORT=5000
NODE_ENV=development
SECRET_KEY=your-secret-key-for-jwt-tokens-change-this

# For production deployment on Render:
# 1. Set NODE_ENV=production
# 2. Generate a secure SECRET_KEY: openssl rand -base64 32
# 3. Keep PORT=5000 (Render will expose it)
